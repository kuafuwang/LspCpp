{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "ci/default",
      "description": "Default profile for CI to build. uses vcpkg, C++17 and vcpkg rapidjson",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "release",
        "USE_SYSTEM_RAPIDJSON": "true",
        "LSPCPP_USE_CPP17": "true",
        "LSPCPP_SUPPORT_BOEHM_GC": "$env{LSPCPP_SUPPORT_BOEHM_GC}",
        "VCPKG_MANIFEST_FEATURES": "$env{LSPCPP_CI_VCPKG_FEATURES}",
        "USE_EXTERNAL_IXWEBSOCKET": "true",
        "USE_EXTERNAL_ASIO": "true",
        "LSPCPP_STANDALONE_ASIO": "true",
        "LSPCPP_BUILD_TESTS": "true",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      },
      "binaryDir": "${sourceDir}/cmake-build-ci"
    },
    {
      "name": "ci/cpp14",
      "description": "CI profile for C++14 compatibility verification without Boehm GC",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "release",
        "USE_SYSTEM_RAPIDJSON": "true",
        "LSPCPP_USE_CPP17": "false",
        "LSPCPP_SUPPORT_BOEHM_GC": "false",
        "VCPKG_MANIFEST_FEATURES": "$env{LSPCPP_CI_VCPKG_FEATURES}",
        "USE_EXTERNAL_IXWEBSOCKET": "true",
        "USE_EXTERNAL_ASIO": "true",
        "LSPCPP_STANDALONE_ASIO": "true",
        "LSPCPP_BUILD_WEBSOCKETS": "false",
        "LSPCPP_BUILD_TESTS": "true",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      },
      "binaryDir": "${sourceDir}/cmake-build-ci-cpp14"
    }
  ],
  "buildPresets": [
    {
      "name": "ci/default",
      "configurePreset": "ci/default"
    },
    {
      "name": "ci/cpp14",
      "configurePreset": "ci/cpp14"
    }
  ],
  "testPresets": [
    {
      "name": "ci/default",
      "configurePreset": "ci/default",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "ci/cpp14",
      "configurePreset": "ci/cpp14",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
